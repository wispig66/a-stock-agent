# 复制为 .env 并填入真实值（.env 已被 .gitignore 屏蔽）

# IM gateway：默认走飞书；可多通道并存（逗号分隔）
CHANNEL_DEFAULT=feishu
CHANNELS_ENABLED=feishu
CHANNELS_NOTIFY=feishu

# 飞书 / Lark（推荐通过 scripts/configure_feishu.py 写入）
FEISHU_ENABLED=1
FEISHU_APP_ID=
FEISHU_APP_SECRET=
FEISHU_HOME_CHANNEL=
FEISHU_ALLOWED_CHAT_IDS=
FEISHU_DOMAIN=feishu
FEISHU_CONNECTION_MODE=websocket
FEISHU_REQUIRE_MENTION=true
FEISHU_CARD=true

# 企业微信智能机器人（长连接，无需公网）。启用：CHANNELS_ENABLED=feishu,wecom
WECOM_BOT_ID=
WECOM_SECRET=
WECOM_HOME_CHANNEL=
WECOM_ALLOWED_USERS=

# 个人微信 iLink（扫码登录，仅 1v1；通过 scripts/configure_weixin.py 写入）
WEIXIN_ACCOUNT_ID=
WEIXIN_TOKEN=
WEIXIN_HOME_CHANNEL=
WEIXIN_ALLOWED_USERS=
WEIXIN_GROUP_POLICY=disabled
