# 复制为 .env 并填入真实值（.env 已被 .gitignore 屏蔽）

# IM gateway：默认只跑飞书 + 个人微信（逗号分隔）
# CHANNELS_ENABLED 控制 listener，CHANNELS_NOTIFY 控制定时推送 fan-out。
CHANNEL_DEFAULT=feishu
CHANNELS_ENABLED=feishu,weixin
CHANNELS_NOTIFY=feishu,weixin

# 飞书 / Lark（推荐通过 scripts/configure_feishu.py 写入）
FEISHU_ENABLED=1
FEISHU_APP_ID=
FEISHU_APP_SECRET=
FEISHU_HOME_CHANNEL=
FEISHU_ALLOWED_CHAT_IDS=
FEISHU_DOMAIN=feishu
FEISHU_CONNECTION_MODE=websocket
FEISHU_REQUIRE_MENTION=true
FEISHU_CARD=true

# 个人微信 iLink（扫码登录，仅 1v1；通过 scripts/configure_weixin.py 写入）
# 首次扫码后先给机器人私聊一条消息，再把 peer id 写入 WEIXIN_HOME_CHANNEL。
WEIXIN_ACCOUNT_ID=
WEIXIN_TOKEN=
WEIXIN_BASE_URL=https://ilinkai.weixin.qq.com
WEIXIN_HOME_CHANNEL=
WEIXIN_ALLOWED_USERS=
WEIXIN_GROUP_POLICY=disabled
