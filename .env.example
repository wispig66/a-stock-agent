# 复制为 .env 并填入真实值（.env 已被 .gitignore 屏蔽）
TG_BOT_TOKEN=
TG_CHAT_ID=

# IM gateway 默认仍走 Telegram；Feishu 先灰度启用
CHANNEL_DEFAULT=telegram
CHANNELS_ENABLED=telegram

# Feishu / Lark（推荐通过 scripts/configure_feishu.py 写入）
FEISHU_ENABLED=0
FEISHU_APP_ID=
FEISHU_APP_SECRET=
FEISHU_HOME_CHANNEL=
FEISHU_ALLOWED_CHAT_IDS=
FEISHU_DOMAIN=feishu
FEISHU_CONNECTION_MODE=websocket
FEISHU_REQUIRE_MENTION=true
FEISHU_REACTIONS=false
